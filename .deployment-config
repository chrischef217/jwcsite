# IMPORTANT: This project uses Genspark Table API
# 
# The Table API is provided by Genspark platform and does NOT require:
# - D1 database setup
# - Cloudflare database configuration  
# - wrangler.toml
# - package.json
#
# Tables defined:
# - images (logo, heroSlider, pageHero)
# - settings (app configuration)
#
# These are managed via Genspark's built-in "tables/" API endpoint.
# No additional database infrastructure needed.

DEPLOYMENT_TYPE=static
USE_GENSPARK_TABLE_API=true
REQUIRE_D1_DATABASE=false
